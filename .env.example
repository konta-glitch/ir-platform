# ── LM Studio (local LLM on Mac host) ──
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=qwen2.5-coder-14b-instruct-mlx

# ── Claude API (optional — for knowledge gap filling) ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── General ──
LOG_LEVEL=INFO
DATA_DIR=/app/data
EXPORT_DIR=/app/exports

# ── Detection rule auto-update (handled by entrypoint.sh on container start) ──
# Both rulesets refresh in the background and never block startup. Defaults are
# sensible; override only if you want different cadence or a bigger YARA set.
#
# Sigma (Hayabusa):
# SIGMA_UPDATE_INTERVAL=86400   # seconds between re-fetches (default 24h)
# SIGMA_FORCE_UPDATE=false      # "true" forces a re-fetch on next start
#
# YARA (YARA-Forge):
# YARA_UPDATE_INTERVAL=86400    # seconds between re-fetches (default 24h)
# YARA_FORCE_UPDATE=false       # "true" forces a re-fetch on next start
# YARA_PACKAGE=core             # core (~5,100 rules) | extended | full

# ── Hash/IOC reputation (optional, local-first) ──
# Drop a local IOC hash feed (abuse.ch, MISP export, or hand-made list) and the
# detection engine flags any file/process/YARA-match whose hash appears in it.
# One hash per line, optional ",note". Default location: $DATA_DIR/ioc_hashes.txt
# IOC_HASH_FILE=/app/data/ioc_hashes.txt

# ── Narrative pass performance (second LLM pass) ──
# Batches run concurrently against the local LLM — this is the biggest speed
# lever, since the narrative pass dominates wall-clock time. Tune concurrency
# to what your LLM server handles without thrashing (LM Studio + 1 model: 2-4).
# NARRATIVE_CONCURRENCY=4
# NARRATIVE_BATCH_SIZE=20
# IR default keeps ALL severities in the narrative (nothing dropped). Narrow
# to "critical,high" only if you deliberately trade coverage for speed.
# NARRATIVE_SEVERITIES=critical,high,medium,low,info
