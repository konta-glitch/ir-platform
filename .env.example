# ── LLM token budget ──
# Reasoning models (DeepSeek-R1, QwQ) spend much of this on their <think>
# block before answering, so a small budget yields empty "0 chars" responses.
# 16000 leaves room for reasoning + the answer. Lower for plain models.
# LLM_MAX_TOKENS=16000
>>>>>>> Stashed changes

# ── Narrative reasoning control (for DeepSeek-R1 / reasoning models) ──
# Reasoning models burn their whole token budget on <think> during the
# narrative pass and never emit JSON (empty content + timeouts). Keep this on
# to make the narrative pass answer directly. Primary analysis still reasons.
# NARRATIVE_DISABLE_THINKING=true
# Per-call timeout (s) for narrative LLM calls — reasoning models are slow.
# NARRATIVE_TIMEOUT=600

# ── LLM call timeout ──
# Baseline per-call timeout (s) for the primary analysis + enrichment passes.
# httpx's 300s default cuts off slow reasoning models (DeepSeek-R1 spends ~170s
# thinking before it answers), causing ReadTimeout on large prompts. 600s is
# comfortable. The narrative pass uses NARRATIVE_TIMEOUT.
# LLM_TIMEOUT=600

# ── Narrative synthesis ──
# After per-batch narratives, run one more pass that folds them into a single
# coherent incident story (related activity split across batches reads as one
# attack). Per-batch sections are kept as fallback. Off = concatenated sections.
# NARRATIVE_SYNTHESIZE=true
