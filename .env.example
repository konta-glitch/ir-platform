# ── LM Studio (local LLM on Mac host) ──
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=qwen2.5-coder-14b-instruct-mlx

# ── Claude API (optional — for knowledge gap filling) ──
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── General ──
LOG_LEVEL=INFO
DATA_DIR=/app/data
EXPORT_DIR=/app/exports

# ── Detection rule auto-update (handled by entrypoint.sh on container start) ──
# Both rulesets refresh in the background and never block startup. Defaults are
# sensible; override only if you want different cadence or a bigger YARA set.
#
# Sigma (Hayabusa):
# SIGMA_UPDATE_INTERVAL=86400   # seconds between re-fetches (default 24h)
# SIGMA_FORCE_UPDATE=false      # "true" forces a re-fetch on next start
#
# YARA (YARA-Forge):
# YARA_UPDATE_INTERVAL=86400    # seconds between re-fetches (default 24h)
# YARA_FORCE_UPDATE=false       # "true" forces a re-fetch on next start
# YARA_PACKAGE=core             # core (~5,100 rules) | extended | full
